{
    "name": "spiderweb/sylius-stancer-plugin",
    "description": "Sylius plugin for Stancer payment gateway",
    "type": "sylius-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Spider Web",
            "homepage": "https://github.com/spiderweb-dev"
        }
    ],
    "require": {
        "php": ">=8.1",
        "payum/core": "^1.7",
        "stancer/stancer": "^2.0",
        "sylius/core-bundle": "^2.0",
        "symfony/form": "^6.4 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "SpiderWeb\\Sylius\\StancerPlugin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SpiderWeb\\Sylius\\StancerPlugin\\Tests\\": "tests/"
        }
    },
    "keywords": ["payum", "stancer", "payment", "sylius", "sylius-plugin"],
    "homepage": "https://github.com/Zalastan/sylius-stancer-plugin"
}
