{
    "name": "spiderweb/payum-stancer",
    "description": "Payum gateway for Stancer payment provider",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Spider Web",
            "homepage": "https://github.com/spiderweb-dev"
        }
    ],
    "require": {
        "php": ">=8.1",
        "payum/core": "^1.7",
        "stancer/stancer": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "SpiderWeb\\PayumStancer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SpiderWeb\\PayumStancer\\Tests\\": "tests/"
        }
    },
    "keywords": ["payum", "stancer", "payment", "sylius"],
    "homepage": "https://github.com/spiderweb-dev/payum-stancer"
}
